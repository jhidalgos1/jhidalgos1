<Window x:Class="JH.QueryStudio.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="JH Query Studio" Height="880" Width="1440" MinHeight="760" MinWidth="1180"
        Background="{StaticResource StudioBackground}" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="68" />
            <RowDefinition Height="*" />
            <RowDefinition Height="32" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#0A1628" BorderBrush="#203755" BorderThickness="0,0,0,1">
            <DockPanel Margin="18,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="44" Height="44" CornerRadius="14" Background="#22D3EE" Margin="0,0,12,0">
                        <Grid>
                            <TextBlock Text="JH" FontWeight="Black" Foreground="#07111F" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <TextBlock Text="&gt;_" FontFamily="Consolas" FontSize="10" Foreground="White" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,4,3" />
                        </Grid>
                    </Border>
                    <StackPanel>
                        <TextBlock Text="JH Query Studio" FontSize="19" FontWeight="Bold" Foreground="#E5F3FF" />
                        <TextBlock Text="Consulta, analiza y controla tus datos." FontSize="12" Foreground="#A5F3FC" />
                    </StackPanel>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="ActiveConnectionText" Text="Sin conexión" Foreground="#AFC4DD" VerticalAlignment="Center" Margin="0,0,16,0" />
                    <Button Content="Probar" Click="TestConnection_Click" Margin="0,0,8,0" Padding="14,7" />
                    <Button Content="Conectar" Click="Connect_Click" Margin="0,0,8,0" Padding="14,7" />
                    <Button Content="Ejecutar F5" Click="Execute_Click" Margin="0,0,8,0" Padding="14,7" Background="#0891B2" Foreground="White" />
                    <Button Content="Limpiar" Click="Clear_Click" Padding="14,7" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource StudioPanel}" BorderBrush="#203755" BorderThickness="1" CornerRadius="14" Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="Conexión SQL Server" Foreground="#E5F3FF" FontWeight="Bold" FontSize="16" Margin="0,0,0,10" />
                        <TextBlock Text="Servidor" Foreground="#AFC4DD" />
                        <TextBox x:Name="ServerTextBox" Text="localhost" Margin="0,3,0,8" />
                        <TextBlock Text="Base de datos" Foreground="#AFC4DD" />
                        <TextBox x:Name="DatabaseTextBox" Text="master" Margin="0,3,0,8" />
                        <TextBlock Text="Usuario" Foreground="#AFC4DD" />
                        <TextBox x:Name="UserTextBox" Text="sa" Margin="0,3,0,8" />
                        <TextBlock Text="Contraseña" Foreground="#AFC4DD" />
                        <PasswordBox x:Name="PasswordBox" Margin="0,3,0,8" />
                        <CheckBox x:Name="TrustCertificateCheckBox" Content="Confiar en certificado" IsChecked="True" Foreground="#DCEBFA" Margin="0,2,0,4" />
                        <CheckBox x:Name="EncryptCheckBox" Content="Cifrar conexión" IsChecked="True" Foreground="#DCEBFA" Margin="0,2,0,12" />
                    </StackPanel>

                    <Separator Grid.Row="1" Margin="0,4,0,12" />

                    <DockPanel Grid.Row="2">
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Explorador" Foreground="#E5F3FF" FontWeight="Bold" FontSize="16" VerticalAlignment="Center" />
                            <Button Content="Actualizar" Click="RefreshMetadata_Click" Margin="12,0,0,0" Padding="10,4" />
                        </StackPanel>
                        <TreeView x:Name="ObjectTree" Background="#081322" Foreground="#E5F3FF" BorderBrush="#203755" />
                    </DockPanel>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch" Background="#12233A" />

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{StaticResource StudioPanel}" BorderBrush="#203755" BorderThickness="1" CornerRadius="14" Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <DockPanel Margin="0,0,0,8">
                            <TextBlock Text="Editor SQL" Foreground="#E5F3FF" FontWeight="Bold" FontSize="16" VerticalAlignment="Center" />
                            <TextBlock DockPanel.Dock="Right" Text="Atajos: F5 ejecutar · Ctrl+L limpiar mensajes" Foreground="#67E8F9" VerticalAlignment="Center" />
                        </DockPanel>
                        <TextBox x:Name="SqlEditorTextBox" Grid.Row="1" AcceptsReturn="True" AcceptsTab="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                 FontFamily="Consolas" FontSize="15" Background="#07111F" Foreground="#E5F3FF" CaretBrush="#22D3EE"
                                 Text="SELECT TOP (100) *&#x0a;FROM sys.tables;" />
                    </Grid>
                </Border>

                <GridSplitter Grid.Row="1" Height="8" HorizontalAlignment="Stretch" Background="#12233A" />

                <Border Grid.Row="2" Background="{StaticResource StudioPanel}" BorderBrush="#203755" BorderThickness="1" CornerRadius="14" Padding="12">
                    <TabControl>
                        <TabItem Header="Resultados">
                            <DataGrid x:Name="ResultsGrid" AutoGenerateColumns="True" IsReadOnly="True" EnableRowVirtualization="True" EnableColumnVirtualization="True" Background="#07111F" Foreground="#E5F3FF" />
                        </TabItem>
                        <TabItem Header="Mensajes">
                            <TextBox x:Name="MessagesTextBox" IsReadOnly="True" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" FontFamily="Consolas" Background="#07111F" Foreground="#DCEBFA" />
                        </TabItem>
                    </TabControl>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="2" Background="#0A1628" BorderBrush="#203755" BorderThickness="0,1,0,0">
            <DockPanel Margin="12,0">
                <TextBlock Text="JH Query Studio — Developed by Junior Hidalgo" Foreground="#93A9C3" VerticalAlignment="Center" />
                <TextBlock x:Name="RuntimeText" DockPanel.Dock="Right" Text="Desktop .NET 8 · Sin API · SQL Server directo" Foreground="#67E8F9" VerticalAlignment="Center" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
