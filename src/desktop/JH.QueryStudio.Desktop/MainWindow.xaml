<Window x:Class="JH.QueryStudio.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="JH Query Studio" Height="860" Width="1440" MinHeight="720" MinWidth="1180"
        Background="{StaticResource StudioBackground}" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64" />
            <RowDefinition Height="*" />
            <RowDefinition Height="32" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#0A1628" BorderBrush="#203755" BorderThickness="0,0,0,1">
            <DockPanel Margin="18,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="42" Height="42" CornerRadius="14" Background="#22D3EE" Margin="0,0,12,0">
                        <Grid>
                            <TextBlock Text="JH" FontWeight="Black" Foreground="#07111F" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <TextBlock Text="&gt;_" FontFamily="Consolas" FontSize="10" Foreground="White" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,4,3" />
                        </Grid>
                    </Border>
                    <StackPanel>
                        <TextBlock Text="JH Query Studio" FontSize="18" FontWeight="Bold" Foreground="#E5F3FF" />
                        <TextBlock Text="Consulta, analiza y controla tus datos." FontSize="12" Foreground="#A5F3FC" />
                    </StackPanel>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="ReloadButton" Content="Recargar" Click="ReloadButton_Click" Margin="8,0" Padding="14,7" />
                    <Button x:Name="OpenBrowserButton" Content="Abrir en navegador" Click="OpenBrowserButton_Click" Padding="14,7" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <wv2:WebView2 x:Name="StudioWebView" Source="http://localhost:5173" />
            <Border x:Name="LoadingPanel" Background="#07111F" Opacity="0.96">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="520">
                    <TextBlock Text="Iniciando JH Query Studio" FontSize="28" FontWeight="Bold" Foreground="#E5F3FF" TextAlignment="Center" />
                    <TextBlock Text="Preparando backend ASP.NET Core, frontend Vite y entorno local de escritorio..." Margin="0,14,0,0" TextWrapping="Wrap" Foreground="#AFC4DD" TextAlignment="Center" />
                    <ProgressBar IsIndeterminate="True" Height="8" Margin="0,28,0,0" Foreground="#22D3EE" />
                    <TextBlock x:Name="StatusText" Text="Verificando servicios locales..." Margin="0,20,0,0" Foreground="#67E8F9" TextAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#0A1628" BorderBrush="#203755" BorderThickness="0,1,0,0">
            <DockPanel Margin="12,0">
                <TextBlock Text="JH Query Studio — Developed by Junior Hidalgo" Foreground="#93A9C3" VerticalAlignment="Center" />
                <TextBlock x:Name="RuntimeText" DockPanel.Dock="Right" Text="Desktop .NET 8 + WebView2" Foreground="#67E8F9" VerticalAlignment="Center" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
