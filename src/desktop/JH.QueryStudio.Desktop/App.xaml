<Application x:Class="JH.QueryStudio.Desktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="StudioBackground" Color="#F4F8FF" />
        <SolidColorBrush x:Key="StudioPanel" Color="#FFFFFF" />
        <SolidColorBrush x:Key="StudioPanelAlt" Color="#EAF3FF" />
        <SolidColorBrush x:Key="StudioAccent" Color="#2563EB" />
        <SolidColorBrush x:Key="StudioAccent2" Color="#06B6D4" />
        <SolidColorBrush x:Key="StudioAccent3" Color="#7C3AED" />
        <SolidColorBrush x:Key="StudioText" Color="#102033" />
        <SolidColorBrush x:Key="StudioMuted" Color="#52667D" />
        <SolidColorBrush x:Key="StudioBorder" Color="#BCD7F5" />

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource StudioAccent}" />
            <Setter Property="BorderBrush" Value="#1D4ED8" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Margin" Value="4,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="{StaticResource StudioText}" />
            <Setter Property="BorderBrush" Value="{StaticResource StudioBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="7,5" />
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="{StaticResource StudioText}" />
            <Setter Property="BorderBrush" Value="{StaticResource StudioBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="7,5" />
        </Style>
    </Application.Resources>
</Application>
